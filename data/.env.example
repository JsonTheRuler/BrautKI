IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# Microsoft Graph connector (required if EMAIL_SOURCE=graph)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX_USER=
